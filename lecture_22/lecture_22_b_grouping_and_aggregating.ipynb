   "metadata": {},
   "outputs": [],
   "source": [
    "def count_unique(col):\n",
    "    return len(col.unique())\n",
    "\n",
    "results_agg = df_results.agg(mean_points = ('points','mean'),\n",
    "                          mean_laps =   ('laps','mean'),\n",
