    "zip_lists = zip(list_1, list_2)\n",
    "\n",
    "\n",
    "print(type(zip_lists))\n",
    "print(zip_lists)\n",
    "\n",
    "# The variable zip_lists is \"associated\" or \"linked\" \n",
    "# with the original lists. It draws the elements from \n",
    "# those lists when needed."
