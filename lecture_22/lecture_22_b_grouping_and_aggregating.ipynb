  {
   "cell_type": "markdown",
   "id": "cdf09d71",
   "metadata": {},
   "source": [
    "# <span style=\"color:red\"> III. Grouping + Aggregating </span>\n",
    "\n",
    "\n",
    "<img src=\"figures/agg.png\" alt=\"drawing\" width=\"400\"/>"
